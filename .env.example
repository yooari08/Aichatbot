# Frontend (Vite) — copy to .env.local for local development

# API base URL (empty = same origin; Vite proxies /api → localhost:8080)
# VITE_API_BASE_URL=

# Show register link on login page (match backend ALLOW_REGISTRATION)
VITE_ALLOW_REGISTRATION=true

# Dev test login buttons on login page (also shown when npm run dev)
VITE_ENABLE_DEV_LOGIN=true

# Supabase (client-safe publishable key only — never use service_role here)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
