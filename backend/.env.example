# Copy to backend/.env for local development.
# In Rancher/K8s, map these to ConfigMap + Secret (see deploy/rancher/).

APP_NAME=ai-chatbot-api
APP_ENV=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# Local dev: SQLite (no Postgres required). Production: PostgreSQL URL.
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# Dev only: auto-create tables on startup (use Alembic in staging/production)
DB_AUTO_CREATE_TABLES=true
ALLOW_REGISTRATION=true
# Dev test accounts (user + admin) — auto-seeded on API startup
SEED_DEV_TEST_USERS=true
# Optional: seed first admin when users table is empty (dev/staging only)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# Chroma (K8s service DNS in cluster: chroma.ai-chatbot.svc.cluster.local)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=enterprise_kb

# JWT — use a strong random secret (min 32 chars); rotate in production
JWT_SECRET_KEY=local-dev-only-change-before-any-shared-environment-32chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# AWS Bedrock — credentials via IAM role in production; do not set keys in prod
AWS_REGION=ap-northeast-2
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# Frontend origin(s), comma-separated
CORS_ORIGINS=http://localhost:5173
